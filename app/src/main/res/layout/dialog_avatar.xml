<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/change_avatar"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        android:textStyle="bold"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/choose_avatar_instruction"
        android:textColor="#333333"
        android:layout_marginTop="4dp"
        android:textSize="14sp"/>

    <!-- TabLayout (optional nếu sau này phân loại avatar) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabAvatar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

    <!-- Avatar Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewAvatars"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:overScrollMode="never"
        android:scrollbars="vertical"/>

    <!-- Select Button -->
    <Button
        android:id="@+id/btnSelectAvatar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/select_avatar_button"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/purple_500"
        android:textColor="@android:color/white"/>

</LinearLayout>