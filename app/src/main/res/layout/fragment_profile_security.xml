<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollProfileSecurity"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:fillViewport="true"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal"
        android:background="#88000000"> <!-- nền mờ đen -->

        <!-- Title -->
        <TextView
            android:id="@+id/txtSecurityTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/security_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/txtSecuritySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/security_subtitle"
            android:textSize="14sp"
            android:textColor="#FFCCFF"
            android:layout_marginBottom="16dp"/>

        <!-- Google login warning -->
        <TextView
            android:id="@+id/txtGoogleInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/google_user_cant_change"
            android:textColor="#FF6666"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <!-- Current Password -->
        <EditText
            android:id="@+id/edtCurrentPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/current_password_hint"
            android:inputType="textPassword"
            android:drawableEnd="@drawable/ic_eye"
            android:drawablePadding="10dp"
            android:background="@drawable/edit_text_bg"
            android:textColor="#FFFFFF"
            android:textColorHint="#CCDDFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <!-- New Password -->
        <EditText
            android:id="@+id/edtNewPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/new_password_hint"
            android:inputType="textPassword"
            android:drawableEnd="@drawable/ic_eye"
            android:drawablePadding="10dp"
            android:background="@drawable/edit_text_bg"
            android:textColor="#FFFFFF"
            android:textColorHint="#CCDDFF"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <!-- Confirm Password -->
        <EditText
            android:id="@+id/edtConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="@string/confirm_password_hint"
            android:inputType="textPassword"
            android:drawableEnd="@drawable/ic_eye"
            android:drawablePadding="10dp"
            android:background="@drawable/edit_text_bg"
            android:textColor="#FFFFFF"
            android:textColorHint="#CCDDFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Change Password Button -->
        <Button
            android:id="@+id/btnChangePassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/change_password_button"
            android:backgroundTint="#FF99FF"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>