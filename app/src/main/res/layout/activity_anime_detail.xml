<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?attr/colorSurface"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Poster -->

        <ImageView
            android:id="@+id/imgBanner"
            android:layout_width="220dp"
            android:layout_height="320dp"
            android:layout_marginTop="16dp"
            android:scaleType="centerCrop"
            android:background="?attr/colorSurfaceVariant"
            android:layout_gravity="center"
            android:contentDescription="Anime poster" />

        <!-- Title -->

        <TextView
            android:id="@+id/txtTitle"
            android:textColor="?attr/colorOnSurface"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Rating -->

        <TextView
            android:id="@+id/txtRating"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Genres -->

        <TextView
            android:id="@+id/txtGenres"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- ================= INFO ================= -->

        <LinearLayout
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtFormat"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtSeason"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtDuration"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtStudio"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtDirector"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Episode -->

            <TextView
                android:id="@+id/txtEpisodes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Episodes: 0"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/txtNextEpisode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorPrimary"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>
            <!-- Views -->

            <TextView
                android:id="@+id/txtViews"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Trailer release time -->

            <TextView
                android:id="@+id/txtUpdated"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/txtTrailerDate"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtChapters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtVolumes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ================= TRAILER ================= -->

        <Button
            android:id="@+id/btnTrailer"
            android:text="@string/play_trailer"
            android:textColor="?attr/colorOnPrimary"
            android:backgroundTint="?attr/colorPrimary"
            android:layout_margin="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
        <Button
            android:id="@+id/btnRead"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/read_online"
            android:visibility="gone"/>
        <!-- ================= FAVORITE ================= -->

        <LinearLayout
            android:id="@+id/layoutFavorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnFavorite"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_favorite_border"
                android:contentDescription="Favorite"
                app:tint="?attr/colorPrimary"/>

            <TextView
                android:id="@+id/txtFavorite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/favorite_add"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Description title -->

        <TextView
            android:text="Description"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Language -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/btnEnglish"
                android:text="EN"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                android:padding="6dp"
                android:background="@drawable/bg_language_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/btnVietnamese"
                android:text="VI"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                android:padding="6dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_language_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Description -->

        <TextView
            android:id="@+id/txtDesc"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:lineSpacingExtra="4dp"
            android:layout_margin="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</ScrollView>