<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.mari.magic">

    <!-- Internet permission -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:theme="@style/Theme.Magic"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:hardwareAccelerated="true">

        <!-- SPLASH SCREEN (LAUNCHER) -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- MAIN APP -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- SEARCH -->
        <activity
            android:name=".ui.search.SearchActivity"
            android:exported="false" />
        <activity android:name=".ui.type.AnimeTypeActivity"/>
        <activity
            android:name=".ui.top.TopAnimeActivity"/>
        <!-- GENRE -->
        <activity
            android:name=".ui.genre.GenreAnimeActivity"
            android:exported="false" />

        <!-- ANIME DETAIL -->
        <activity
            android:name=".ui.detail.AnimeDetailActivity"
            android:exported="false" />

        <!-- TRAILER -->
        <activity
            android:name=".ui.detail.AnimeTrailerActivity"
            android:exported="false"
            android:hardwareAccelerated="false"/>

        <!-- AUTH -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"/>

        <activity
            android:name=".auth.SignupFormActivity"
            android:exported="false"/>

        <activity
            android:name=".auth.AuthActivity"
            android:exported="false"/>

        <!-- WELCOME SCREEN -->
        <activity
            android:name=".auth.WelcomeActivity"
            android:exported="false"/>

        <activity
            android:name=".ui.season.SeasonAnimeActivity"
            android:exported="false"/>
        <activity
            android:name=".ui.home.SeeAllActivity"
            android:exported="false"/>
    </application>

</manifest>